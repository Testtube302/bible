# ===========================================
# Scripture Bible PWA - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# LLM Configuration
# -------------------------------------------
# Provider: "kimi" or "anthropic"
LLM_PROVIDER=kimi
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-k2.5
LLM_API_KEY=your-moonshot-api-key-here
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=2048

# -------------------------------------------
# PostgreSQL
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bible
POSTGRES_USER=bible_user
POSTGRES_PASSWORD=change-me-in-production

# -------------------------------------------
# ChromaDB
# -------------------------------------------
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# -------------------------------------------
# Admin Authentication
# -------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=generate-a-random-64-char-string-here

# -------------------------------------------
# Backend Server
# -------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3002

# -------------------------------------------
# Frontend (NEXT_PUBLIC_ vars are inlined at build time)
# -------------------------------------------
NEXT_PUBLIC_API_URL=/bible/api
NEXT_PUBLIC_WS_URL=ws://localhost/bible/api/chat
NEXT_PUBLIC_BASE_PATH=/bible
